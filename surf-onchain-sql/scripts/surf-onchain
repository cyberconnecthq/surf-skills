#!/usr/bin/env bash
# surf-onchain — CLI for OnchainSQL queries via Hermod API
# Usage: surf-onchain query "SELECT ..." [--max-rows N]
#        surf-onchain --check-setup

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-onchain",
  "subcommands": {
    "query": {"args": "<sql> [--max-rows N]", "description": "Execute a read-only SQL query against ClickHouse"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

cmd_query() {
  local sql=""
  local max_rows=1000

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-rows) max_rows="$2"; shift 2 ;;
      *) sql="$1"; shift ;;
    esac
  done

  if [[ -z "$sql" ]]; then
    echo '{"error": "SQL query is required. Usage: surf-onchain query \"SELECT ...\""}' >&2
    return 1
  fi

  local payload
  payload=$(printf '{"sql": %s, "max_rows": %d}' "$(echo "$sql" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))')" "$max_rows")

  surf_post "/v1/onchain/query" "$payload"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;
  query) shift; cmd_query "$@" ;;
  *) echo "{\"error\": \"Unknown command: $1. Use --help for usage.\"}" >&2; exit 1 ;;
esac
