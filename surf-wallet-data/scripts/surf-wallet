#!/usr/bin/env bash
# surf-wallet — CLI for wallet data via Hermod API
# Usage: surf-wallet <subcommand> [--address ADDR] [--query Q]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/wallet"

ALL_COMMANDS="balance, token-list, transfer, trading-history, transaction-history, label, debank-balance, debank-tokens, debank-defi, debank-chains, debank-history, debank-net-curve, etherscan-txs, etherscan-tokens, etherscan-gas, etherscan-abi, etherscan-sourcecode, etherscan-contract-creation, moralis-net-worth, moralis-profitability, moralis-stats, moralis-swaps, moralis-defi, moralis-ens, moralis-ens-reverse, sol-account, sol-account-tokens, sol-account-txs, sol-account-transfers, sol-account-defi, sol-balance-change"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-wallet",
  "subcommands": {
    "balance":             {"args": "--address ADDR [--chain eth] [--limit N]", "description": "Get wallet balance (1 credit)"},
    "token-list":          {"args": "--address ADDR [--chain eth] [--limit N]", "description": "List token holdings (1 credit)"},
    "transfer":            {"args": "--address ADDR [--chain eth] [--limit N]", "description": "Get transfer history (1 credit)"},
    "trading-history":     {"args": "--address ADDR [--limit N]", "description": "Get trading history (1 credit)"},
    "transaction-history": {"args": "--address ADDR [--chain eth] [--limit N]", "description": "Get transaction history (1 credit)"},
    "label":               {"args": "--address ADDR", "description": "Look up address label and entity (1 credit)"},
    "debank-balance":      {"args": "--address ADDR", "description": "DeBank cross-chain balance (5 credits, proxy)"},
    "debank-tokens":       {"args": "--address ADDR", "description": "DeBank all token balances (5 credits, proxy)"},
    "debank-defi":         {"args": "--address ADDR", "description": "DeBank DeFi positions (5 credits, proxy)"},
    "debank-chains":       {"args": "--address ADDR", "description": "DeBank active chains (5 credits, proxy)"},
    "debank-history":      {"args": "--address ADDR [--chain eth] [--limit 20]", "description": "DeBank full tx history (5 credits, proxy)"},
    "debank-net-curve":    {"args": "--address ADDR", "description": "DeBank portfolio value over time (5 credits, proxy)"},
    "etherscan-txs":       {"args": "--address ADDR [--chainid 1]", "description": "Etherscan tx history (4 credits, proxy)"},
    "etherscan-tokens":    {"args": "--address ADDR [--chainid 1]", "description": "Etherscan token transfers (4 credits, proxy)"},
    "etherscan-gas":       {"args": "[--chainid 1]", "description": "Etherscan gas prices (4 credits, proxy)"},
    "etherscan-abi":       {"args": "--address ADDR [--chainid 1]", "description": "Etherscan contract ABI (4 credits, proxy)"},
    "etherscan-sourcecode":{"args": "--address ADDR [--chainid 1]", "description": "Etherscan contract source code (4 credits, proxy)"},
    "etherscan-contract-creation":{"args": "--address ADDR [--chainid 1]", "description": "Etherscan contract creation info (4 credits, proxy)"},
    "moralis-net-worth":   {"args": "--address ADDR [--exclude-spam true]", "description": "Moralis wallet net worth across all chains (2 credits, proxy). Auto scans all EVM chains"},
    "moralis-profitability":{"args": "--address ADDR [--chain eth]", "description": "Moralis wallet P&L summary — trades, realized profit (2 credits, proxy). Chains: eth, polygon, base"},
    "moralis-stats":       {"args": "--address ADDR [--chain eth]", "description": "Moralis wallet stats — NFTs, collections, txs, transfers (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, etc."},
    "moralis-swaps":       {"args": "--address ADDR [--chain eth] [--limit 10] [--cursor TOKEN]", "description": "Moralis wallet DEX swaps (2 credits, proxy). Returns cursor for pagination. Chains: all EVM"},
    "moralis-defi":        {"args": "--address ADDR [--chain eth]", "description": "Moralis wallet DeFi positions summary (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base"},
    "moralis-ens":         {"args": "--domain NAME", "description": "ENS domain to address lookup (2 credits, proxy). Ethereum ENS only"},
    "moralis-ens-reverse": {"args": "--address ADDR", "description": "Address to ENS domain reverse lookup (2 credits, proxy). Ethereum only"},
    "sol-account":         {"args": "--address ADDR", "description": "Solana account detail (4 credits, proxy)"},
    "sol-account-tokens":  {"args": "--address ADDR [--page 1] [--page-size 10]", "description": "Solana account SPL token holdings (4 credits, proxy). type: token or nft. page_size: 10,20,30,40"},
    "sol-account-txs":     {"args": "--address ADDR [--limit 10]", "description": "Solana account transactions (4 credits, proxy). limit: 10,20,30,40,60,100"},
    "sol-account-transfers":{"args": "--address ADDR [--page 1] [--page-size 10]", "description": "Solana account token transfers (4 credits, proxy). page_size: 10,20,30,40,60,100"},
    "sol-account-defi":    {"args": "--address ADDR [--page 1] [--page-size 10]", "description": "Solana account DeFi activities (4 credits, proxy). page_size: 10,20,30,40,60,100"},
    "sol-balance-change":  {"args": "--address ADDR [--page 1] [--page-size 10]", "description": "Solana account balance changes (4 credits, proxy). page_size: 10,20,30,40,60,100"},
    "--check-setup":       {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --address)  query="${query:+$query&}address=$2"; shift 2 ;;
      --chain)    query="${query:+$query&}chain=$2"; shift 2 ;;
      --limit)    query="${query:+$query&}limit=$2"; shift 2 ;;
      --offset)   query="${query:+$query&}offset=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --offset\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Semantic endpoints
  balance|token-list|transfer|trading-history|transaction-history)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;
  label)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_get "${API_PREFIX}/label/${addr}"
    ;;

  # DeBank proxy
  debank-balance)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/user/total_balance" "id=${addr}"
    ;;
  debank-tokens)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/user/all_token_list" "id=${addr}"
    ;;
  debank-defi)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/user/all_complex_protocol_list" "id=${addr}"
    ;;
  debank-chains)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/user/used_chain_list" "id=${addr}"
    ;;
  debank-history)
    shift; addr=""; chain=""; limit="20"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    q="id=${addr}&page_count=${limit}"
    [[ -n "$chain" ]] && q="${q}&chain_id=${chain}"
    surf_proxy_get "debank" "/v1/user/all_history_list" "$q"
    ;;
  debank-net-curve)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/user/total_net_curve" "id=${addr}"
    ;;

  # Etherscan proxy
  etherscan-txs)
    shift; addr=""; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chainid\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=account&action=txlist&address=${addr}&startblock=0&endblock=99999999&page=1&offset=100&sort=desc"
    ;;
  etherscan-tokens)
    shift; addr=""; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chainid\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=account&action=tokentx&address=${addr}&page=1&offset=100&sort=desc"
    ;;
  etherscan-gas)
    shift; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --chainid\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=gastracker&action=gasoracle"
    ;;
  etherscan-abi)
    shift; addr=""; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chainid\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (contract address, e.g. 0xdac17f958d2ee523a2206206994597c13d831ec7)"}' >&2; exit 1; }
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=contract&action=getabi&address=${addr}"
    ;;
  etherscan-sourcecode)
    shift; addr=""; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chainid\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (contract address, e.g. 0xdac17f958d2ee523a2206206994597c13d831ec7)"}' >&2; exit 1; }
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=contract&action=getsourcecode&address=${addr}"
    ;;
  etherscan-contract-creation)
    shift; addr=""; chainid="1"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chainid) chainid="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chainid\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (contract address, e.g. 0xdac17f958d2ee523a2206206994597c13d831ec7)"}' >&2; exit 1; }
    surf_proxy_get "etherscan" "/v2/api" "chainid=${chainid}&module=contract&action=getcontractcreation&contractaddresses=${addr}"
    ;;

  # Moralis proxy (wallet analytics)
  moralis-net-worth)
    shift; addr=""; exclude_spam=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --exclude-spam) exclude_spam="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --exclude-spam\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    q=""; [[ -n "$exclude_spam" ]] && q="exclude_spam=${exclude_spam}"
    surf_proxy_get "moralis" "/wallets/${addr}/net-worth" "$q"
    ;;
  moralis-profitability)
    shift; addr=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/wallets/${addr}/profitability/summary" "chain=${chain}"
    ;;
  moralis-stats)
    shift; addr=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/wallets/${addr}/stats" "chain=${chain}"
    ;;
  moralis-swaps)
    shift; addr=""; chain="eth"; limit="10"; cursor=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; --cursor) cursor="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --cursor\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    q="chain=${chain}&limit=${limit}"
    [[ -n "$cursor" ]] && q="${q}&cursor=${cursor}"
    surf_proxy_get "moralis" "/wallets/${addr}/swaps" "$q"
    ;;
  moralis-defi)
    shift; addr=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/wallets/${addr}/defi/summary" "chain=${chain}"
    ;;
  moralis-ens)
    shift; domain=""
    while [[ $# -gt 0 ]]; do case "$1" in --domain) domain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --domain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$domain" ]] && { echo '{"error": "--domain is required (ENS domain, e.g. vitalik.eth)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/resolve/ens/${domain}" ""
    ;;
  moralis-ens-reverse)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/resolve/${addr}/reverse" ""
    ;;

  # Solscan proxy (Solana account-level queries)
  sol-account)
    shift; addr=""
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/detail" "address=${addr}"
    ;;
  sol-account-tokens)
    shift; addr=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/token-accounts" "address=${addr}&type=token&page=${page}&page_size=${page_size}"
    ;;
  sol-account-txs)
    shift; addr=""; limit="10"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --limit\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/transactions" "address=${addr}&limit=${limit}"
    ;;
  sol-account-transfers)
    shift; addr=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/transfer" "address=${addr}&page=${page}&page_size=${page_size}"
    ;;
  sol-account-defi)
    shift; addr=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/defi/activities" "address=${addr}&page=${page}&page_size=${page_size}"
    ;;
  sol-balance-change)
    shift; addr=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --address) addr="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$addr" ]] && { echo '{"error": "--address is required (Solana address, e.g. vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/account/balance_change" "address=${addr}&page=${page}&page_size=${page_size}"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
