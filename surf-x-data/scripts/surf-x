#!/usr/bin/env bash
# surf-x — CLI for X/Twitter data via Hermod API
# Usage: surf-x <subcommand> [--handle HANDLE] [--query Q] [--ids JSON_ARRAY]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/x"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-x",
  "subcommands": {
    "search":        {"args": "--query QUERY [--limit 20]", "description": "Search tweets (3 credits)"},
    "user":          {"args": "--handle HANDLE", "description": "Get user profile (2 credits)"},
    "tweets":        {"args": "--handle HANDLE [--limit 20]", "description": "Get user tweets (3 credits)"},
    "get-tweets":    {"args": "--ids JSON_ARRAY", "description": "Get tweets by IDs (2 credits)"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;
  search)
    shift
    local_query=""
    local_limit=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) local_query="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_query" ]]; then
      echo '{"error": "--query is required"}' >&2; exit 1
    fi
    # JSON-encode the query string safely
    local_json_query=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$local_query")
    local_body="{\"query\": $local_json_query}"
    # Truncate results client-side if --limit specified
    if [[ -n "$local_limit" ]]; then
      surf_post "${API_PREFIX}/search" "$local_body" | python3 -c "
import json,sys
d=json.load(sys.stdin)
limit=int(sys.argv[1])
if 'data' in d and 'tweets' in d['data']:
    d['data']['tweets']=d['data']['tweets'][:limit]
json.dump(d,sys.stdout)
" "$local_limit"
    else
      surf_post "${API_PREFIX}/search" "$local_body"
    fi
    ;;
  user)
    shift
    local_handle=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --handle) local_handle="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --handle\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_handle" ]]; then
      echo '{"error": "--handle is required"}' >&2; exit 1
    fi
    surf_get "${API_PREFIX}/user/${local_handle}"
    ;;
  tweets)
    shift
    local_handle=""
    local_limit=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --handle) local_handle="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --handle, --limit\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_handle" ]]; then
      echo '{"error": "--handle is required"}' >&2; exit 1
    fi
    if [[ -n "$local_limit" ]]; then
      surf_get "${API_PREFIX}/user/${local_handle}/tweets" | python3 -c "
import json,sys
d=json.load(sys.stdin)
limit=int(sys.argv[1])
if 'data' in d and 'tweets' in d['data']:
    d['data']['tweets']=d['data']['tweets'][:limit]
json.dump(d,sys.stdout)
" "$local_limit"
    else
      surf_get "${API_PREFIX}/user/${local_handle}/tweets"
    fi
    ;;
  get-tweets)
    shift
    local_ids=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids) local_ids="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --ids\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_ids" ]]; then
      echo '{"error": "--ids is required (JSON array)"}' >&2; exit 1
    fi
    surf_post "${API_PREFIX}/tweets" "{\"tweet_ids\": $local_ids}"
    ;;
  *) echo "{\"error\": \"Unknown command: $1. Available: search, user, tweets, get-tweets\"}" >&2; exit 1 ;;
esac
