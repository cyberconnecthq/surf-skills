#!/usr/bin/env bash
# surf-session — Manage Hermod API Gateway session
# All commands are non-interactive. Agent drives the flow with separate commands.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SURF_CORE_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
SESSION_DIR="${HOME}/.surf-core"
SESSION_FILE="${SESSION_DIR}/session.json"

# Muninn auth base (same domain, different path prefix)
: "${MUNINN_URL:=https://api.stg.ask.surf/muninn}"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-session",
  "subcommands": {
    "login":      {"args": "[--url URL]", "description": "Open browser for Google Sign-In. One-click login."},
    "refresh":    {"args": "", "description": "Refresh access token using saved refresh token"},
    "configure":  {"args": "--token JWT [--url URL]", "description": "Manually save a JWT session (no refresh token)"},
    "check":      {"args": "", "description": "Verify session connectivity (calls /v1/health)"},
    "status":     {"args": "", "description": "Show current session info (JWT payload, expiry)"},
    "credits":    {"args": "", "description": "Check credit balance and plan"},
    "logout":     {"args": "", "description": "Remove saved session"}
  },
  "login_flow": [
    "surf-session login",
    "# → Opens Google Sign-In in browser. Click to login. Session saved automatically."
  ]
}}
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

ensure_session_dir() {
  mkdir -p "$SESSION_DIR"
}

# Save session to ~/.surf-core/session.json
save_session() {
  local access_token="$1"
  local hermod_url="$2"
  local refresh_token="${3:-}"

  ensure_session_dir
  python3 -c "
import json, sys
data = {
    'hermod_url': sys.argv[1],
    'hermod_token': sys.argv[2],
}
if sys.argv[3]:
    data['refresh_token'] = sys.argv[3]
with open(sys.argv[4], 'w') as f:
    json.dump(data, f, indent=2)
" "$hermod_url" "$access_token" "$refresh_token" "$SESSION_FILE"

  chmod 600 "$SESSION_FILE"
}

# Read a field from session file
read_session_field() {
  local field="$1"
  python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get(sys.argv[2],''))" "$SESSION_FILE" "$field" 2>/dev/null || echo ""
}

# Load session: env vars > session file
load_session() {
  if [[ -n "${HERMOD_TOKEN:-}" ]]; then
    : # env var already set
  elif [[ -f "$SESSION_FILE" ]]; then
    HERMOD_TOKEN=$(read_session_field "hermod_token")
    local file_url
    file_url=$(read_session_field "hermod_url")
    if [[ -n "$file_url" ]]; then
      : "${HERMOD_URL:=$file_url}"
    fi
  fi

  : "${HERMOD_URL:=https://api.stg.ask.surf/gateway}"

  if [[ -z "${HERMOD_TOKEN:-}" ]]; then
    echo '{"error": "No session found. Run: surf-session login"}' >&2
    return 1
  fi
}

# Decode JWT payload (base64url → JSON)
decode_jwt_payload() {
  local token="$1"
  local payload
  payload=$(echo "$token" | cut -d. -f2)

  local padded
  padded=$(echo "$payload" | tr '_-' '/+')
  local mod=$((${#padded} % 4))
  if [[ $mod -eq 2 ]]; then padded="${padded}=="
  elif [[ $mod -eq 3 ]]; then padded="${padded}="
  fi

  echo "$padded" | base64 -d 2>/dev/null
}

# Check if access token expires within N seconds (default 300 = 5 min)
token_expires_soon() {
  local token="$1"
  local threshold="${2:-300}"
  local payload_json
  payload_json=$(decode_jwt_payload "$token")
  if [[ -z "$payload_json" ]]; then return 0; fi

  local exp now
  exp=$(echo "$payload_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('exp',0))" 2>/dev/null) || exp=0
  now=$(date +%s)

  if [[ "$exp" -gt 0 && $((exp - now)) -le "$threshold" ]]; then
    return 0  # expires soon or already expired
  fi
  return 1  # still valid
}

# POST to Muninn, return body + http_code (last line)
muninn_post() {
  local path="$1"
  local body="$2"

  curl -s --max-time 15 -w "\n%{http_code}" \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    -d "$body" \
    "${MUNINN_URL}${path}" 2>/dev/null
}

# Extract http_code (last line) and body (rest) from curl output
parse_curl_response() {
  local raw="$1"
  RESP_CODE=$(echo "$raw" | tail -1)
  RESP_BODY=$(echo "$raw" | sed '$d')
}

# Extract .data.field from Muninn JSON response
extract_data_field() {
  local json="$1"
  local field="$2"
  python3 -c "import json,sys; print(json.load(sys.stdin).get('data',{}).get(sys.argv[1],''))" "$field" <<< "$json" 2>/dev/null || echo ""
}

# Format remaining seconds as human string
format_remaining() {
  local remaining="$1"
  if [[ $remaining -gt 86400 ]]; then
    echo "$((remaining / 86400))d $((remaining % 86400 / 3600))h"
  elif [[ $remaining -gt 3600 ]]; then
    echo "$((remaining / 3600))h $((remaining % 3600 / 60))m"
  elif [[ $remaining -gt 0 ]]; then
    echo "$((remaining / 60))m"
  else
    echo "expired"
  fi
}

# Compute token_expires_in from an access_token
token_expiry_human() {
  local token="$1"
  local payload_json
  payload_json=$(decode_jwt_payload "$token")
  local exp
  exp=$(echo "$payload_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('exp',0))" 2>/dev/null) || exp=0
  local now
  now=$(date +%s)
  format_remaining $((exp - now))
}

# ---------------------------------------------------------------------------
# Login: Browser-based Google Sign-In (one-click)
# ---------------------------------------------------------------------------

# ANSI colors
_GREEN='\033[0;32m'
_RED='\033[0;31m'
_NC='\033[0m'

_fail() {
  printf "${_RED}%s${_NC}\n" "$1" >&2
  return 1
}

cmd_login() {
  local hermod_url=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url) hermod_url="$2"; shift 2 ;;
      *) _fail "Unknown flag: $1" ;;
    esac
  done

  : "${hermod_url:=https://api.stg.ask.surf/gateway}"

  command -v python3 &>/dev/null || _fail "python3 is required"

  # Run the OAuth browser helper, capture credential from stdout
  local oauth_output
  oauth_output=$(python3 "${SCRIPT_DIR}/_oauth_browser.py" 2>/dev/null) || _fail "Login failed or timed out"

  local credential
  credential=$(echo "$oauth_output" | python3 -c "import json,sys; print(json.load(sys.stdin).get('credential',''))" 2>/dev/null)
  [[ -z "$credential" ]] && _fail "No credential received from browser"

  # Exchange Google credential for Hermod session
  local login_body
  login_body=$(python3 -c "import json,sys; print(json.dumps({'credentials': sys.argv[1], 'platform': 'WEB'}))" "$credential")

  local raw
  raw=$(muninn_post "/v2/auth/oauth/google" "$login_body") || _fail "Connection failed"

  parse_curl_response "$raw"
  [[ "$RESP_CODE" -ge 400 ]] && _fail "Login failed (HTTP $RESP_CODE)"

  local access_token refresh_token
  access_token=$(extract_data_field "$RESP_BODY" "access_token")
  refresh_token=$(extract_data_field "$RESP_BODY" "refresh_token")
  [[ -z "$access_token" ]] && _fail "No token in response"

  save_session "$access_token" "$hermod_url" "$refresh_token"

  printf "${_GREEN}Login successful${_NC}\n"
}

# ---------------------------------------------------------------------------
# Refresh: use saved refresh_token to get a new access_token
# ---------------------------------------------------------------------------

cmd_refresh() {
  if [[ ! -f "$SESSION_FILE" ]]; then
    echo '{"error": "No session file. Login first: surf-session login"}' >&2
    return 1
  fi

  local refresh_token hermod_url
  refresh_token=$(read_session_field "refresh_token")
  hermod_url=$(read_session_field "hermod_url")
  : "${hermod_url:=https://api.stg.ask.surf/gateway}"

  if [[ -z "$refresh_token" ]]; then
    echo '{"error": "No refresh_token in session. Login again: surf-session login"}' >&2
    return 1
  fi

  local raw
  raw=$(muninn_post "/v2/auth/refresh" "{\"refresh_token\": \"$refresh_token\"}") || {
    echo '{"error": "Failed to connect to Muninn for token refresh."}' >&2
    return 1
  }

  parse_curl_response "$raw"

  if [[ "$RESP_CODE" -ge 400 ]]; then
    echo "{\"error\": \"Token refresh failed\", \"http_status\": $RESP_CODE, \"response\": $RESP_BODY}" >&2
    return 1
  fi

  local new_access_token new_refresh_token
  new_access_token=$(extract_data_field "$RESP_BODY" "access_token")
  new_refresh_token=$(extract_data_field "$RESP_BODY" "refresh_token")

  if [[ -z "$new_access_token" ]]; then
    echo "{\"error\": \"No access_token in refresh response\", \"response\": $RESP_BODY}" >&2
    return 1
  fi

  : "${new_refresh_token:=$refresh_token}"

  save_session "$new_access_token" "$hermod_url" "$new_refresh_token"

  local expires_in
  expires_in=$(token_expiry_human "$new_access_token")

  echo "{\"status\": \"refreshed\", \"token_expires_in\": \"$expires_in\", \"session_file\": \"$SESSION_FILE\"}"
}

# ---------------------------------------------------------------------------
# Auto-refresh: silently refresh if access_token expires within 5 minutes
# ---------------------------------------------------------------------------

load_session_with_refresh() {
  load_session || return 1

  if token_expires_soon "$HERMOD_TOKEN" 300; then
    local refresh_token
    refresh_token=$(read_session_field "refresh_token")
    if [[ -n "$refresh_token" ]]; then
      local raw
      raw=$(muninn_post "/v2/auth/refresh" "{\"refresh_token\": \"$refresh_token\"}") 2>/dev/null || return 0
      parse_curl_response "$raw"
      if [[ "$RESP_CODE" -lt 400 ]]; then
        local new_access new_refresh
        new_access=$(extract_data_field "$RESP_BODY" "access_token")
        new_refresh=$(extract_data_field "$RESP_BODY" "refresh_token")
        if [[ -n "$new_access" ]]; then
          : "${new_refresh:=$refresh_token}"
          save_session "$new_access" "$HERMOD_URL" "$new_refresh"
          HERMOD_TOKEN="$new_access"
          echo '{"auto_refresh": true, "message": "Access token refreshed automatically."}' >&2
        fi
      fi
    fi
  fi
}

# ---------------------------------------------------------------------------
# Configure: manual JWT (backward compat)
# ---------------------------------------------------------------------------

cmd_configure() {
  local token="" url=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --token) token="$2"; shift 2 ;;
      --url)   url="$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; return 1 ;;
    esac
  done

  if [[ -z "$token" ]]; then
    echo '{"error": "--token is required. Or use: surf-session login"}' >&2
    return 1
  fi

  if [[ ! "$token" =~ ^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$ ]]; then
    echo '{"error": "Invalid JWT format. Expected: header.payload.signature"}' >&2
    return 1
  fi

  local payload_json
  payload_json=$(decode_jwt_payload "$token")
  if [[ -n "$payload_json" ]]; then
    local exp
    exp=$(echo "$payload_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('exp',0))" 2>/dev/null) || exp=0
    local now
    now=$(date +%s)
    if [[ "$exp" -gt 0 && "$exp" -le "$now" ]]; then
      echo '{"error": "Token is already expired."}' >&2
      return 1
    fi
  fi

  : "${url:=https://api.stg.ask.surf/gateway}"

  save_session "$token" "$url"

  echo "{\"status\": \"configured\", \"hermod_url\": \"$url\", \"session_file\": \"$SESSION_FILE\"}"
}

# ---------------------------------------------------------------------------
# Check / Status / Credits / Logout
# ---------------------------------------------------------------------------

cmd_check() {
  load_session_with_refresh || return 1

  local http_code body
  body=$(curl -s --max-time 10 -w "\n%{http_code}" \
    -H "Authorization: Bearer ${HERMOD_TOKEN}" \
    -H "Accept: application/json" \
    "${HERMOD_URL}/v1/health" 2>/dev/null) || {
    echo '{"error": "Connection failed. Check HERMOD_URL and network."}' >&2
    return 1
  }

  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')

  if [[ "$http_code" -ge 400 ]]; then
    echo "{\"error\": \"Health check failed\", \"http_status\": $http_code, \"response\": $body}" >&2
    return 1
  fi

  echo "{\"status\": \"connected\", \"hermod_url\": \"$HERMOD_URL\", \"health\": $body}"
}

cmd_status() {
  load_session || return 1

  local payload_json
  payload_json=$(decode_jwt_payload "$HERMOD_TOKEN")

  if [[ -z "$payload_json" ]]; then
    echo '{"error": "Failed to decode JWT payload"}' >&2
    return 1
  fi

  local has_refresh="false"
  if [[ -f "$SESSION_FILE" ]]; then
    local rt
    rt=$(read_session_field "refresh_token")
    [[ -n "$rt" ]] && has_refresh="true"
  fi

  python3 -c "
import json, sys, time

payload = json.loads(sys.argv[1])
exp = payload.get('exp', 0)
now = int(time.time())
remaining = exp - now

status = {
    'hermod_url': sys.argv[2],
    'user_id': payload.get('user_id') or payload.get('sub'),
    'deploy_id': payload.get('deploy_id'),
    'ssid': payload.get('ssid'),
    'expires_at': exp,
    'expired': remaining <= 0,
    'remaining_seconds': max(remaining, 0),
    'has_refresh_token': sys.argv[3] == 'true',
}

if remaining > 86400:
    status['remaining_human'] = f'{remaining // 86400}d {(remaining % 86400) // 3600}h'
elif remaining > 3600:
    status['remaining_human'] = f'{remaining // 3600}h {(remaining % 3600) // 60}m'
elif remaining > 0:
    status['remaining_human'] = f'{remaining // 60}m'
else:
    status['remaining_human'] = 'EXPIRED'

print(json.dumps(status, indent=2))
" "$payload_json" "$HERMOD_URL" "$has_refresh"
}

cmd_credits() {
  load_session_with_refresh || return 1

  local http_code body
  body=$(curl -s --max-time 10 -w "\n%{http_code}" \
    -H "Authorization: Bearer ${HERMOD_TOKEN}" \
    -H "Accept: application/json" \
    "${HERMOD_URL}/v1/me/credit-summary" 2>/dev/null) || {
    echo '{"error": "Request failed. Check session with: surf-session check"}' >&2
    return 1
  }

  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')

  if [[ "$http_code" -ge 400 ]]; then
    echo "$body" >&2
    return 1
  fi

  echo "$body"
}

cmd_logout() {
  if [[ -f "$SESSION_FILE" ]]; then
    rm -f "$SESSION_FILE"
    echo '{"status": "logged_out", "message": "Session removed"}'
  else
    echo '{"status": "no_session", "message": "No session file found"}'
  fi
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
case "${1:---help}" in
  --help|-h)     usage ;;
  login)         shift; cmd_login "$@" ;;
  configure)     shift; cmd_configure "$@" ;;
  refresh)       cmd_refresh ;;
  check)         cmd_check ;;
  status)        cmd_status ;;
  credits)       cmd_credits ;;
  logout)        cmd_logout ;;
  *) echo "{\"error\": \"Unknown command: $1. Use --help for usage.\"}" >&2; exit 1 ;;
esac
