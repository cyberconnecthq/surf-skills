#!/usr/bin/env bash
# surf-auth — restish External Tool auth script
# Reads token from ~/.surf-core/session.json, auto-refreshes if near expiry,
# outputs JSON headers for restish to use as Bearer auth.
#
# stdout: {"headers":{"authorization":["Bearer <token>"]}}
# stderr: diagnostics (restish ignores stderr from external tools)

set -euo pipefail

SURF_SESSION_FILE="${HOME}/.surf-core/session.json"
: "${MUNINN_URL:=https://api.stg.ask.surf/muninn}"

# --- Read session ---
if [[ ! -f "$SURF_SESSION_FILE" ]]; then
  echo "Error: No session file at $SURF_SESSION_FILE. Run: surf-session login" >&2
  exit 1
fi

HERMOD_TOKEN=$(python3 -c "
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    token = data.get('hermod_token', '') or data.get('access_token', '')
    if not token:
        raise ValueError('no token')
    print(token)
except Exception as e:
    print(f'Error reading session: {e}', file=sys.stderr)
    sys.exit(1)
" "$SURF_SESSION_FILE") || exit 1

# --- Decode JWT exp and check if refresh needed ---
_needs_refresh=$(python3 -c "
import json, sys, base64, time
token = sys.argv[1]
try:
    payload = token.split('.')[1]
    payload += '=' * (4 - len(payload) % 4)
    d = json.loads(base64.urlsafe_b64decode(payload))
    exp = d.get('exp', 0)
    if exp > 0 and (exp - time.time()) <= 300:
        print('yes')
    else:
        print('no')
except Exception:
    print('no')
" "$HERMOD_TOKEN" 2>/dev/null) || _needs_refresh="no"

# --- Refresh token if needed ---
if [[ "$_needs_refresh" == "yes" ]]; then
  _refresh_token=$(python3 -c "
import json, sys
data = json.load(open(sys.argv[1]))
print(data.get('refresh_token', ''))
" "$SURF_SESSION_FILE" 2>/dev/null) || _refresh_token=""

  if [[ -n "$_refresh_token" ]]; then
    _raw=$(curl -s --max-time 10 -w "\n%{http_code}" -X POST \
      -H "Content-Type: application/json" \
      -H "Accept: application/json" \
      -d "{\"refresh_token\": \"$_refresh_token\"}" \
      "${MUNINN_URL}/v2/auth/refresh" 2>/dev/null) || _raw=""

    if [[ -n "$_raw" ]]; then
      _http_code=$(echo "$_raw" | tail -1)
      _body=$(echo "$_raw" | sed '$d')

      if [[ "$_http_code" -lt 400 ]]; then
        _new_token=$(python3 -c "
import json, sys
data = json.load(sys.stdin).get('data', {})
token = data.get('access_token', '')
if not token:
    sys.exit(1)
print(token)
" <<< "$_body" 2>/dev/null) || _new_token=""

        if [[ -n "$_new_token" ]]; then
          _new_refresh=$(python3 -c "
import json, sys
print(json.load(sys.stdin).get('data', {}).get('refresh_token', ''))
" <<< "$_body" 2>/dev/null) || _new_refresh=""
          : "${_new_refresh:=$_refresh_token}"

          HERMOD_TOKEN="$_new_token"

          # Update session file
          _hermod_url=$(python3 -c "
import json, sys
print(json.load(open(sys.argv[1])).get('hermod_url', 'https://api.stg.ask.surf/gateway'))
" "$SURF_SESSION_FILE" 2>/dev/null) || _hermod_url="https://api.stg.ask.surf/gateway"

          python3 -c "
import json, sys
data = json.load(open(sys.argv[1]))
data['hermod_token'] = sys.argv[2]
data['access_token'] = sys.argv[2]
data['refresh_token'] = sys.argv[3]
with open(sys.argv[1], 'w') as f:
    json.dump(data, f, indent=2)
" "$SURF_SESSION_FILE" "$_new_token" "$_new_refresh" 2>/dev/null

          echo '{"auto_refresh": true, "message": "Access token refreshed."}' >&2
        fi
      else
        echo "Warning: Token refresh failed (HTTP $_http_code). Run: surf-session login" >&2
      fi
    fi
  fi
fi

# --- Output auth headers for restish ---
python3 -c "
import json, sys
print(json.dumps({'headers': {'authorization': ['Bearer ' + sys.argv[1]]}}))
" "$HERMOD_TOKEN"
