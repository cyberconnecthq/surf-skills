#!/usr/bin/env bash
# surf-token — CLI for token data via Hermod API
# Usage: surf-token <subcommand> [flags]
#
# Hermod routes token endpoints to different upstreams:
#   - holder/transfer → Moralis/Etherscan (token address + chain)
#   - exchange-flow/exchange-reserve → CryptoQuant (asset symbol)
#   - etf-flow → SoSoValue (type)

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/token-data"

ALL_COMMANDS="holder, transfer, exchange-flow, etf-flow, exchange-reserve, moralis-holders, moralis-meta, moralis-transfers, moralis-price, moralis-search, moralis-trending, moralis-top-gainers, moralis-top-losers, moralis-blue-chip, moralis-pair-stats, moralis-global-market-cap, sol-holders, sol-transfers, sol-price, sol-meta, sol-trending, sol-markets, debank-top-holders"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-token",
  "subcommands": {
    "holder":           {"args": "--token 0x... --chain eth [--limit 5]", "description": "Moralis token holders (1 credit)"},
    "transfer":         {"args": "--token 0x... --chain eth [--page 1] [--offset 5]", "description": "Etherscan token transfers (1 credit)"},
    "exchange-flow":    {"args": "--asset btc --flow-type netflow [--exchange all_exchange] [--window day] [--limit 3]", "description": "CryptoQuant exchange flow (1 credit)"},
    "etf-flow":         {"args": "--type us-btc-spot", "description": "SoSoValue ETF flow (1 credit). Types: us-btc-spot, us-eth-spot"},
    "exchange-reserve": {"args": "--asset btc [--exchange all_exchange] [--window day] [--limit 3]", "description": "CryptoQuant exchange reserve (1 credit)"},
    "moralis-holders":  {"args": "--token ADDR [--chain eth]", "description": "Moralis top holders (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, avalanche, optimism, linea, fantom, cronos"},
    "moralis-meta":     {"args": "--token ADDR [--chain eth]", "description": "Moralis token metadata (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, avalanche, optimism, linea, fantom, cronos"},
    "moralis-transfers":{"args": "--token ADDR [--chain eth] [--limit 100]", "description": "Moralis token transfers (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, avalanche, optimism, linea, fantom, cronos"},
    "moralis-price":    {"args": "--token ADDR [--chain eth]", "description": "Moralis token price with DEX data (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, avalanche, optimism, linea, fantom, cronos"},
    "moralis-search":   {"args": "--query NAME [--chain eth] [--limit 5] [--cursor TOKEN]", "description": "Search tokens by name/symbol (2 credits, proxy). Chains: all EVM + solana"},
    "moralis-trending": {"args": "[--chain eth] [--limit 10]", "description": "Trending tokens by chain (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base, avalanche, optimism, linea, fantom, cronos, solana, etc."},
    "moralis-top-gainers":{"args": "[--chain eth]", "description": "Top gaining tokens on-chain (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base"},
    "moralis-top-losers":{"args": "[--chain eth]", "description": "Top losing tokens on-chain (2 credits, proxy). Chains: eth, bsc, polygon, arbitrum, base"},
    "moralis-blue-chip":{"args": "[--chain eth]", "description": "Blue-chip tokens with strong fundamentals (2 credits, proxy). Chains: eth, bsc"},
    "moralis-pair-stats":{"args": "--pair ADDR [--chain eth]", "description": "DEX pair stats — price, liquidity, volume (2 credits, proxy). Chains: all EVM"},
    "moralis-global-market-cap":{"args": "", "description": "Global crypto market cap rankings (2 credits, proxy). No chain param needed"},
    "sol-holders":      {"args": "--token MINT [--page 1] [--page-size 10]", "description": "Solscan token holders (4 credits, proxy). page_size: 10,20,30,40"},
    "sol-transfers":    {"args": "--token MINT [--page 1] [--page-size 10]", "description": "Solscan token transfers (4 credits, proxy). page_size: 10,20,30,40,60,100"},
    "sol-price":        {"args": "--token MINT", "description": "Solscan token price history (4 credits, proxy)"},
    "sol-meta":         {"args": "--token MINT", "description": "Solscan token metadata — name, symbol, supply, market cap, price (4 credits, proxy)"},
    "sol-trending":     {"args": "[--limit 10]", "description": "Solscan trending tokens on Solana (4 credits, proxy). limit: 10,20,30,40,60,100"},
    "sol-markets":      {"args": "--token MINT [--page 1] [--page-size 10]", "description": "Solscan DEX trading pairs/pools for a token (4 credits, proxy). page_size: 10,20,30,40"},
    "debank-top-holders": {"args": "--token ADDR --chain eth [--limit 10]", "description": "DeBank top token holders with USD values (5 credits, proxy)"},
    "--check-setup":    {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --token)     query="${query:+$query&}token=$2"; shift 2 ;;
      --chain)     query="${query:+$query&}chain=$2"; shift 2 ;;
      --asset)     query="${query:+$query&}asset=$2"; shift 2 ;;
      --flow-type) query="${query:+$query&}flow_type=$2"; shift 2 ;;
      --exchange)  query="${query:+$query&}exchange=$2"; shift 2 ;;
      --window)    query="${query:+$query&}window=$2"; shift 2 ;;
      --type)      query="${query:+$query&}type=$2"; shift 2 ;;
      --limit)     query="${query:+$query&}limit=$2"; shift 2 ;;
      --page)      query="${query:+$query&}page=$2"; shift 2 ;;
      --offset)    query="${query:+$query&}offset=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain, --asset, --flow-type, --exchange, --window, --type, --limit, --page, --offset\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Semantic endpoints
  holder|transfer|exchange-flow|etf-flow|exchange-reserve)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  # Moralis proxy
  moralis-holders)
    shift; token=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (ERC-20 contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/${token}/owners" "chain=${chain}&order=DESC&limit=100"
    ;;
  moralis-meta)
    shift; token=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (ERC-20 contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/metadata" "chain=${chain}&addresses[]=${token}"
    ;;
  moralis-transfers)
    shift; token=""; chain="eth"; limit="100"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain, --limit\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (ERC-20 contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/${token}/transfers" "chain=${chain}&limit=${limit}"
    ;;

  moralis-price)
    shift; token=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (ERC-20 contract address, e.g. 0xdac17f958d2ee523a2206206994597c13d831ec7)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/erc20/${token}/price" "chain=${chain}"
    ;;
  moralis-search)
    shift; query=""; chain="eth"; limit="5"; cursor=""
    while [[ $# -gt 0 ]]; do case "$1" in --query) query="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; --cursor) cursor="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --chain, --limit, --cursor\"}" >&2; exit 1 ;; esac; done
    [[ -z "$query" ]] && { echo '{"error": "--query is required (token name or symbol, e.g. pepe)"}' >&2; exit 1; }
    q="query=${query}&chain=${chain}&limit=${limit}"
    [[ -n "$cursor" ]] && q="${q}&cursor=${cursor}"
    surf_proxy_get "moralis" "/tokens/search" "$q"
    ;;
  moralis-trending)
    shift; chain="eth"; limit="10"
    while [[ $# -gt 0 ]]; do case "$1" in --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --chain, --limit\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "moralis" "/tokens/trending" "chain=${chain}&limit=${limit}"
    ;;
  moralis-top-gainers)
    shift; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --chain\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "moralis" "/discovery/tokens/top-gainers" "chain=${chain}"
    ;;
  moralis-top-losers)
    shift; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --chain\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "moralis" "/discovery/tokens/top-losers" "chain=${chain}"
    ;;
  moralis-blue-chip)
    shift; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --chain\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "moralis" "/discovery/tokens/blue-chip" "chain=${chain}"
    ;;
  moralis-pair-stats)
    shift; pair=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --pair) pair="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --pair, --chain\"}" >&2; exit 1 ;; esac; done
    [[ -z "$pair" ]] && { echo '{"error": "--pair is required (DEX pair address, e.g. 0x11b815efB8f581194ae79006d24E0d814B7697F6)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/pairs/${pair}/stats" "chain=${chain}"
    ;;
  moralis-global-market-cap)
    shift
    surf_proxy_get "moralis" "/market-data/global/market-cap" ""
    ;;

  # Solscan proxy (v2.0 uses "address" param)
  sol-holders)
    shift; token=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address, e.g. EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/holders" "address=${token}&page=${page}&page_size=${page_size}"
    ;;
  sol-transfers)
    shift; token=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address, e.g. EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/transfer" "address=${token}&page=${page}&page_size=${page_size}"
    ;;
  sol-price)
    shift; token=""
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address, e.g. EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/price" "address=${token}"
    ;;
  sol-meta)
    shift; token=""
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address, e.g. EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/meta" "address=${token}"
    ;;
  sol-trending)
    shift; limit="10"
    while [[ $# -gt 0 ]]; do case "$1" in --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --limit\"}" >&2; exit 1 ;; esac; done
    surf_proxy_get "solscan" "/v2.0/token/trending" "limit=${limit}"
    ;;
  sol-markets)
    shift; token=""; page="1"; page_size="10"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; --page-size) page_size="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --page, --page-size\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address, e.g. EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/markets" "token%5B%5D=${token}&page=${page}&page_size=${page_size}"
    ;;

  # DeBank proxy
  debank-top-holders)
    shift; token=""; chain="eth"; limit="10"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1. Valid: --token, --chain, --limit\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (ERC-20 contract address, e.g. 0xdac17f958d2ee523a2206206994597c13d831ec7)"}' >&2; exit 1; }
    surf_proxy_get "debank" "/v1/token/top_holders" "id=${token}&chain_id=${chain}&limit=${limit}"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
