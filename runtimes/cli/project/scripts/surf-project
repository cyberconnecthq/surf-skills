        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id monad or --q monad)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/discover/tweets" "$local_qs"
    ;;

  events)
    shift
    local_id="" local_q="" local_type=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        --type) local_type="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q, --type\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id uniswap or --q uniswap)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    [[ -n "$local_type" ]] && local_qs="${local_qs:+${local_qs}&}type=$local_type"
    surf_get "${API_PREFIX}/events" "$local_qs"
    ;;

  funding)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
