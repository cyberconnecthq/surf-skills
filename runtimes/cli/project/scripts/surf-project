#!/usr/bin/env bash
# surf-project — CLI for project data via Hermod API
# Usage: surf-project <subcommand> [flags]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/project"

ALL_COMMANDS="contracts, discover, discover-fdv, discover-summary, discover-tweets, events, funding, listings, metrics, mindshare, mindshare-by-tag, mindshare-geo, mindshare-lang, mindshare-leaderboard, overview, search, smart-followers, smart-followers-events, smart-followers-history, smart-followers-members, social, tags, team, token-info, tokenomics, top, vc-portfolio"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-project",
  "subcommands": {
    "contracts": {"args": "--id ethereum | --q ethereum", "description": "Get project contracts (1 credit)"},
    "discover": {"args": "", "description": "Discover projects (1 credit)"},
    "discover-fdv": {"args": "--id ethereum | --q monad", "description": "Get discover project FDV (1 credit)"},
    "discover-summary": {"args": "--id ethereum | --q monad", "description": "Get discover project summary (1 credit)"},
    "discover-tweets": {"args": "--id ethereum | --q monad", "description": "Get discover project tweets (1 credit)"},
    "events": {"args": "--id ethereum | --q uniswap [--type general]", "description": "Get project events (1 credit)"},
    "funding": {"args": "--id ethereum | --q uniswap", "description": "Get project funding history (1 credit)"},
    "listings": {"args": "--id ethereum | --q uniswap", "description": "Get project exchange listings (1 credit)"},
    "metrics": {"args": "--id ethereum --metric volume [--start 2024-01-01] [--end 2024-12-31] [--chain eth]", "description": "Get project metrics (1 credit)"},
    "mindshare": {"args": "--id ethereum | --q bitcoin [--timeframe 7d]", "description": "Get project mindshare (1 credit)"},
    "mindshare-by-tag": {"args": "--id ethereum | --q bitcoin", "description": "Get project mindshare by tag (1 credit)"},
    "mindshare-geo": {"args": "--id ethereum | --q bitcoin", "description": "Get project mindshare by geography (1 credit)"},
    "mindshare-lang": {"args": "--id ethereum | --q bitcoin", "description": "Get project mindshare by language (1 credit)"},
    "mindshare-leaderboard": {"args": "--id ethereum | --q bitcoin", "description": "Get project mindshare leaderboard (1 credit)"},
    "overview": {"args": "--id ethereum | --q ethereum", "description": "Get project overview (1 credit)"},
    "search": {"args": "--query bitcoin [--limit 20]", "description": "Search projects (1 credit)"},
    "smart-followers": {"args": "--id ethereum | --q bitcoin [--timeframe 30d]", "description": "Get project smart followers (1 credit)"},
    "smart-followers-events": {"args": "--id ethereum | --q uniswap", "description": "Get project smart followers events (1 credit)"},
    "smart-followers-history": {"args": "--id ethereum | --q uniswap", "description": "Get project smart followers history (1 credit)"},
    "smart-followers-members": {"args": "--id ethereum | --q uniswap", "description": "Get project smart followers members (1 credit)"},
    "social": {"args": "--id ethereum | --q uniswap", "description": "Get project social links (1 credit)"},
    "tags": {"args": "[--id ethereum | --q ethereum]", "description": "Get project tags (1 credit)"},
    "team": {"args": "--id ethereum | --q uniswap", "description": "Get project team (1 credit)"},
    "token-info": {"args": "--id ethereum | --q uniswap", "description": "Get project token info (1 credit)"},
    "tokenomics": {"args": "--id ethereum | --q uniswap", "description": "Get project tokenomics (1 credit)"},
    "top": {"args": "--metric tvl", "description": "Get top/ranked projects (1 credit)"},
    "vc-portfolio": {"args": "--id ethereum | --q a16z", "description": "Get VC portfolio (1 credit)"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Build query string from --id and --q values
# Usage: _build_entity_qs "$local_id" "$local_q"
_build_entity_qs() {
  local id_val="$1" q_val="$2"
  local qs=""
  [[ -n "$id_val" ]] && qs="id=$(surf_urlencode "$id_val")"
  [[ -n "$q_val" ]] && qs="${qs:+${qs}&}q=$(surf_urlencode "$q_val")"
  echo "$qs"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  contracts)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q ethereum)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/contracts" "$local_qs"
    ;;

  discover)
    shift
    surf_get "${API_PREFIX}/discover"
    ;;

  discover-fdv)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id monad or --q monad)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/discover/fdv" "$local_qs"
    ;;

  discover-summary)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id monad or --q monad)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/discover/summary" "$local_qs"
    ;;

  discover-tweets)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
