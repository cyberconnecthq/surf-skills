    surf_get "${API_PREFIX}/funding" "$local_qs"
    ;;

  listings)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q uniswap)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/listings" "$local_qs"
    ;;

  metrics)
    shift
    local_id="" local_metric="" local_start="" local_end="" local_chain=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --metric) local_metric="$2"; shift 2 ;;
        --start) local_start="$2"; shift 2 ;;
        --end) local_end="$2"; shift 2 ;;
        --chain) local_chain="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --metric, --start, --end, --chain\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" ]]; then
      echo '{"error": "--id is required (e.g. aave, lido, uniswap — must match Token Terminal)"}' >&2; exit 1
    fi
    if [[ -z "$local_metric" ]]; then
      echo '{"error": "--metric is required. Valid: volume, fee, revenue, tvl, users"}' >&2; exit 1
    fi
    if [[ -n "$local_metric" ]] && [[ "$local_metric" != "volume" ]] && [[ "$local_metric" != "fee" ]] && [[ "$local_metric" != "revenue" ]] && [[ "$local_metric" != "tvl" ]] && [[ "$local_metric" != "users" ]]; then
      echo '{"error": "--metric invalid. Valid: volume, fee, revenue, tvl, users"}' >&2; exit 1
    fi
    local_qs="id=$(surf_urlencode "$local_id")"
    local_qs="${local_qs}&metric=$(surf_urlencode "$local_metric")"
    [[ -n "$local_start" ]] && local_qs="${local_qs:+${local_qs}&}start=$local_start"
    [[ -n "$local_end" ]] && local_qs="${local_qs:+${local_qs}&}end=$local_end"
    [[ -n "$local_chain" ]] && local_qs="${local_qs:+${local_qs}&}chain=$local_chain"
    surf_get "${API_PREFIX}/metrics" "$local_qs"
    ;;

  mindshare)
    shift
    local_id="" local_q="" local_timeframe="7d"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        --timeframe) local_timeframe="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q, --timeframe\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id bitcoin or --q bitcoin)"}' >&2; exit 1
    fi
    if [[ -n "$local_timeframe" ]] && [[ "$local_timeframe" != "1d" ]] && [[ "$local_timeframe" != "7d" ]] && [[ "$local_timeframe" != "30d" ]]; then
      echo '{"error": "--timeframe invalid. Valid: 1d, 7d, 30d"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    [[ -n "$local_timeframe" ]] && local_qs="${local_qs:+${local_qs}&}timeframe=$local_timeframe"
    surf_get "${API_PREFIX}/mindshare" "$local_qs"
    ;;

  mindshare-by-tag)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id bitcoin or --q bitcoin)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
