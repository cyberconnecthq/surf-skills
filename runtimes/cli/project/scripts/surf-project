    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/token-info" "$local_qs"
    ;;

  tokenomics)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q uniswap)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/tokenomics" "$local_qs"
    ;;

  top)
    shift
    local_metric=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --metric) local_metric="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --metric\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_metric" ]]; then
      echo '{"error": "--metric is required. Valid: tvl, revenue, fees, dau, developers, pf_ratio, ps_ratio, dex_volume, lending, stablecoins, upcoming_tge, upcoming_airdrop, new_listing"}' >&2; exit 1
    fi
    if [[ -n "$local_metric" ]] && [[ "$local_metric" != "tvl" ]] && [[ "$local_metric" != "revenue" ]] && [[ "$local_metric" != "fees" ]] && [[ "$local_metric" != "dau" ]] && [[ "$local_metric" != "developers" ]] && [[ "$local_metric" != "pf_ratio" ]] && [[ "$local_metric" != "ps_ratio" ]] && [[ "$local_metric" != "dex_volume" ]] && [[ "$local_metric" != "lending" ]] && [[ "$local_metric" != "stablecoins" ]] && [[ "$local_metric" != "upcoming_tge" ]] && [[ "$local_metric" != "upcoming_airdrop" ]] && [[ "$local_metric" != "new_listing" ]]; then
      echo '{"error": "--metric invalid. Valid: tvl, revenue, fees, dau, developers, pf_ratio, ps_ratio, dex_volume, lending, stablecoins, upcoming_tge, upcoming_airdrop, new_listing"}' >&2; exit 1
    fi
    local_qs="metric=$(surf_urlencode "$local_metric")"
    surf_get "${API_PREFIX}/top" "$local_qs"
    ;;

  vc-portfolio)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id a16z or --q paradigm)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/vc-portfolio" "$local_qs"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
