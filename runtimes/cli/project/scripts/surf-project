    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q ethereum)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/overview" "$local_qs"
    ;;

  search)
    shift
    local_query="" local_limit="20"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) local_query="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_query" ]]; then
      echo '{"error": "--query is required (e.g. uniswap, bitcoin, ETH)"}' >&2; exit 1
    fi
    local_qs="q=$(surf_urlencode "$local_query")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    surf_get "${API_PREFIX}/search" "$local_qs"
    ;;

  smart-followers)
    shift
    local_id="" local_q="" local_timeframe=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        --timeframe) local_timeframe="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q, --timeframe\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q bitcoin)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    [[ -n "$local_timeframe" ]] && local_qs="${local_qs:+${local_qs}&}timeframe=$local_timeframe"
    surf_get "${API_PREFIX}/smart-followers" "$local_qs"
    ;;

  smart-followers-events)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "one of --id or --q is required (e.g. --id ethereum or --q uniswap)"}' >&2; exit 1
    fi
    local_qs=$(_build_entity_qs "$local_id" "$local_q")
    surf_get "${API_PREFIX}/smart-followers/events" "$local_qs"
    ;;

  smart-followers-history)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
