#!/usr/bin/env bash
# surf-market — CLI for crypto market data via Hermod API
# Usage: surf-market <subcommand> [flags]
#
# TODO: This script will be fully updated when hermod /v1/market/* endpoints are finalized.
# For now it supports the core endpoints that have been migrated from trading-data.

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/market"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-market",
  "subcommands": {
    "price":            {"args": "--ids bitcoin,ethereum [--vs usd] [--include-24hr-change]", "description": "Spot price (1 credit)"},
    "futures":          {"args": "--symbol BTC [--limit 5]", "description": "Futures OI (1 credit). WARNING: returns large JSON, use --limit"},
    "options":          {"args": "--symbol BTC [--limit 5]", "description": "Options data (1 credit)"},
    "liquidation":      {"args": "--symbol BTC [--limit 5]", "description": "Liquidation data (1 credit)"},
    "indicator":        {"args": "--name rsi --symbol BTC/USDT [--interval 1d] [--exchange binance]", "description": "Technical indicator (1 credit)"},
    "market-indicator": {"args": "--asset btc --metric sopr [--window day] [--limit 2]", "description": "On-chain market indicator (1 credit)"},
    "etf":              {"args": "--type us-btc-spot", "description": "ETF flows (1 credit). Types: us-btc-spot, us-eth-spot"},
    "volume":           {"args": "--symbol BTC [--limit 5]", "description": "Trading volume (1 credit)"},
    "search":           {"args": "--query solana", "description": "Search coins/tokens (1 credit)"},
    "top":              {"args": "[--limit 10]", "description": "Top coins by market cap (1 credit)"},
    "trending":         {"args": "", "description": "Trending coins (1 credit)"},
    "--check-setup":    {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Build query string from flags
build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ids)       query="${query:+$query&}ids=$2"; shift 2 ;;
      --vs)        query="${query:+$query&}vs_currencies=$2"; shift 2 ;;
      --include-24hr-change) query="${query:+$query&}include_24hr_change=true"; shift ;;
      --symbol)    query="${query:+$query&}symbol=$2"; shift 2 ;;
      --name)      query="${query:+$query&}name=$2"; shift 2 ;;
      --interval)  query="${query:+$query&}interval=$2"; shift 2 ;;
      --exchange)  query="${query:+$query&}exchange=$2"; shift 2 ;;
      --asset)     query="${query:+$query&}asset=$2"; shift 2 ;;
      --metric)    query="${query:+$query&}metric=$2"; shift 2 ;;
      --window)    query="${query:+$query&}window=$2"; shift 2 ;;
      --type)      query="${query:+$query&}type=$2"; shift 2 ;;
      --limit)     query="${query:+$query&}limit=$2"; shift 2 ;;
      --query)     query="${query:+$query&}query=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1. Valid: --ids, --vs, --include-24hr-change, --symbol, --name, --interval, --exchange, --asset, --metric, --window, --type, --limit, --query\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Endpoints that can return large arrays — support --limit for truncation
  futures|options|liquidation|volume)
    subcmd="$1"; shift
    _limit=""
    _args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --limit) _limit="$2"; shift 2 ;;
        *) _args+=("$1"); shift ;;
      esac
    done
    query=$(build_query "${_args[@]+"${_args[@]}"}")
    if [[ -n "$_limit" ]]; then
      surf_get "${API_PREFIX}/${subcmd}" "$query" | python3 -c "
import json,sys
d=json.load(sys.stdin)
limit=int(sys.argv[1])
if isinstance(d,dict):
    inner=d.get('data',d)
    if isinstance(inner,list) and len(inner)>limit:
        if 'data' in d:
            d['data']=inner[:limit]
        else:
            d=inner[:limit]
    elif isinstance(inner,dict):
        for k,v in inner.items():
            if isinstance(v,list) and len(v)>limit:
                inner[k]=v[:limit]
json.dump(d,sys.stdout)
" "$_limit"
    else
      surf_get "${API_PREFIX}/${subcmd}" "$query"
    fi
    ;;

  price|indicator|market-indicator|etf)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  search)
    shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/search" "$query"
    ;;

  top)
    shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/top" "$query"
    ;;

  trending)
    shift
    surf_get "${API_PREFIX}/trending"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: price, futures, options, liquidation, indicator, market-indicator, etf, volume, search, top, trending\"}" >&2; exit 1 ;;
esac
