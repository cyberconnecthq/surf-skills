#!/usr/bin/env bash
# surf-social — CLI for social data via Hermod API
# Usage: surf-social <subcommand> [flags]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/social"

ALL_COMMANDS="follower-geo, search, sentiment, top, tweets, user, user-posts, user-related"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-social",
  "subcommands": {
    "follower-geo": {"args": "--q bitcoin | --id <id> | --handle cz_binance", "description": "Get follower geography (1 credit)"},
    "search": {"args": "--query bitcoin [--limit 20] [--offset 0]", "description": "Search social content (1 credit)"},
    "sentiment": {"args": "--id ethereum | --q ethereum", "description": "Get sentiment analysis (1 credit)"},
    "top": {"args": "--metric trending [--limit 20] [--offset 0]", "description": "Get top social content (1 credit)"},
    "tweets": {"args": "", "description": "Get tweets by IDs (1 credit)"},
    "user": {"args": "--handle vitalikbuterin", "description": "Get social user profile (1 credit)"},
    "user-posts": {"args": "--handle vitalikbuterin [--limit 20] [--offset 0]", "description": "Get user posts (1 credit)"},
    "user-related": {"args": "--handle vitalikbuterin", "description": "Get related accounts (1 credit)"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  follower-geo)
    shift
    local_id="" local_q="" local_handle=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        --handle) local_handle="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q, --handle\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" && -z "$local_handle" ]]; then
      echo '{"error": "--id, --q, or --handle is required (e.g. --q bitcoin, --handle cz_binance)"}' >&2; exit 1
    fi
    local_qs=""
    if [[ -n "$local_id" ]]; then
      local_qs="id=$(surf_urlencode "$local_id")"
    elif [[ -n "$local_q" ]]; then
      local_qs="q=$(surf_urlencode "$local_q")"
    else
      local_qs="handle=$(surf_urlencode "$local_handle")"
    fi
    surf_get "${API_PREFIX}/follower-geo" "$local_qs"
    ;;

  search)
    shift
    local_query="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) local_query="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_query" ]]; then
      echo '{"error": "--query is required (e.g. bitcoin, from:cz_binance)"}' >&2; exit 1
    fi
    local_qs="q=$(surf_urlencode "$local_query")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/search" "$local_qs"
    ;;

  sentiment)
    shift
    local_id="" local_q=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --id) local_id="$2"; shift 2 ;;
        --q) local_q="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --id, --q\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_id" && -z "$local_q" ]]; then
      echo '{"error": "--id or --q is required (e.g. bitcoin, uniswap, ethereum)"}' >&2; exit 1
    fi
    local_qs=""
    if [[ -n "$local_id" ]]; then
      local_qs="id=$(surf_urlencode "$local_id")"
    else
      local_qs="q=$(surf_urlencode "$local_q")"
    fi
    surf_get "${API_PREFIX}/sentiment" "$local_qs"
    ;;

  top)
    shift
    local_metric="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --metric) local_metric="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --metric, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_metric" ]]; then
      echo '{"error": "--metric is required. Valid: trending, engagement"}' >&2; exit 1
    fi
    if [[ -n "$local_metric" ]] && [[ "$local_metric" != "trending" ]] && [[ "$local_metric" != "engagement" ]]; then
      echo '{"error": "--metric invalid. Valid: trending, engagement"}' >&2; exit 1
    fi
    local_qs="metric=$(surf_urlencode "$local_metric")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/top" "$local_qs"
    ;;

  tweets)
    shift
    local_ids=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids) local_ids="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --ids\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_ids" ]]; then
      echo '{"error": "--ids is required (JSON array of tweet IDs, max 100)"}' >&2; exit 1
    fi
    surf_post "${API_PREFIX}/tweets" "{\"tweet_ids\": $local_ids}"
    ;;

  user)
    shift
    local_handle=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --handle) local_handle="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --handle\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_handle" ]]; then
      echo '{"error": "--handle is required (e.g. cz_binance, vitalikbuterin)"}' >&2; exit 1
    fi
    local_qs="handle=$(surf_urlencode "$local_handle")"
    surf_get "${API_PREFIX}/user" "$local_qs"
    ;;

  user-posts)
    shift
    local_handle="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --handle) local_handle="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --handle, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_handle" ]]; then
      echo '{"error": "--handle is required (e.g. cz_binance)"}' >&2; exit 1
    fi
    local_qs="handle=$(surf_urlencode "$local_handle")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/user/posts" "$local_qs"
    ;;

  user-related)
    shift
    local_handle=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --handle) local_handle="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --handle\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_handle" ]]; then
      echo '{"error": "--handle is required (e.g. cz_binance)"}' >&2; exit 1
    fi
    local_qs="handle=$(surf_urlencode "$local_handle")"
    surf_get "${API_PREFIX}/user/related" "$local_qs"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
