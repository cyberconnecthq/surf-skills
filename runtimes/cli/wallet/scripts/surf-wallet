#!/usr/bin/env bash
# surf-wallet — CLI for wallet data via Hermod API
# Usage: surf-wallet <subcommand> [flags]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/wallet"

ALL_COMMANDS="balance, history, labels, labels-batch, nft, pnl, search, tokens, top, transfers"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-wallet",
  "subcommands": {
    "balance": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "description": "Get wallet balance (1 credit)"},
    "history": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045 [--chain eth] [--limit 20] [--offset 0]", "description": "Get wallet transaction history (1 credit)"},
    "labels": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "description": "Get wallet labels (1 credit)"},
    "labels-batch": {"args": "", "description": "Batch get wallet labels (1 credit)"},
    "nft": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045 [--chain eth] [--limit 20] [--offset 0]", "description": "Get wallet NFTs (1 credit)"},
    "pnl": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "description": "Get wallet PnL (1 credit)"},
    "search": {"args": "--query bitcoin [--limit 20] [--offset 0]", "description": "Search wallets (1 credit)"},
    "tokens": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045 [--chain eth] [--limit 20] [--offset 0]", "description": "Get wallet token holdings (1 credit)"},
    "top": {"args": "--metric balance [--limit 20] [--offset 0]", "description": "Get top/ranked wallets (1 credit)"},
    "transfers": {"args": "--address 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045 [--chain eth] [--limit 20] [--offset 0]", "description": "Get wallet transfers (1 credit)"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  balance)
    shift
    local_address=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    surf_get "${API_PREFIX}/balance" "$local_qs"
    ;;

  history)
    shift
    local_address="" local_chain="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        --chain) local_chain="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    if [[ -n "$local_chain" ]] && [[ "$local_chain" != "eth" ]] && [[ "$local_chain" != "bsc" ]] && [[ "$local_chain" != "matic" ]] && [[ "$local_chain" != "avax" ]] && [[ "$local_chain" != "ftm" ]] && [[ "$local_chain" != "arb" ]] && [[ "$local_chain" != "op" ]]; then
      echo '{"error": "--chain invalid. Valid: eth, bsc, matic, avax, ftm, arb, op"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    [[ -n "$local_chain" ]] && local_qs="${local_qs:+${local_qs}&}chain=$local_chain"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/history" "$local_qs"
    ;;

  labels)
    shift
    local_address=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    surf_get "${API_PREFIX}/labels" "$local_qs"
    ;;

  labels-batch)
    shift
    local_addresses=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --addresses) local_addresses="$2"; shift 2 ;;
        *) echo '{"error": "Unknown flag: $1. Valid: --addresses"}' >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_addresses" ]]; then
      echo '{"error": "--addresses is required (JSON array of hex addresses)"}' >&2; exit 1
    fi
    surf_post "${API_PREFIX}/labels/batch" "{\"addresses\": $local_addresses}"
    ;;

  nft)
    shift
    local_address="" local_chain="eth" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        --chain) local_chain="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    if [[ -n "$local_chain" ]] && [[ "$local_chain" != "eth" ]] && [[ "$local_chain" != "bsc" ]] && [[ "$local_chain" != "polygon" ]] && [[ "$local_chain" != "avalanche" ]] && [[ "$local_chain" != "fantom" ]] && [[ "$local_chain" != "arbitrum" ]] && [[ "$local_chain" != "optimism" ]]; then
      echo '{"error": "--chain invalid. Valid: eth, bsc, polygon, avalanche, fantom, arbitrum, optimism"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    [[ -n "$local_chain" ]] && local_qs="${local_qs:+${local_qs}&}chain=$local_chain"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/nft" "$local_qs"
    ;;

  pnl)
    shift
    local_address=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    surf_get "${API_PREFIX}/pnl" "$local_qs"
    ;;

  search)
    shift
    local_query="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) local_query="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_query" ]]; then
      echo '{"error": "--query is required (e.g. binance)"}' >&2; exit 1
    fi
    local_qs="q=$(surf_urlencode "$local_query")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/search" "$local_qs"
    ;;

  tokens)
    shift
    local_address="" local_chain="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        --chain) local_chain="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format, e.g. 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045)"}' >&2; exit 1
    fi
    if [[ -n "$local_chain" ]] && [[ "$local_chain" != "eth" ]] && [[ "$local_chain" != "bsc" ]] && [[ "$local_chain" != "matic" ]] && [[ "$local_chain" != "avax" ]] && [[ "$local_chain" != "ftm" ]] && [[ "$local_chain" != "arb" ]] && [[ "$local_chain" != "op" ]]; then
      echo '{"error": "--chain invalid. Valid: eth, bsc, matic, avax, ftm, arb, op"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    [[ -n "$local_chain" ]] && local_qs="${local_qs:+${local_qs}&}chain=$local_chain"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/tokens" "$local_qs"
    ;;

  top)
    shift
    local_metric="" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --metric) local_metric="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --metric, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_metric" ]]; then
      echo '{"error": "--metric is required. Valid: balance, pnl, hyperliquid_whales"}' >&2; exit 1
    fi
    if [[ -n "$local_metric" ]] && [[ "$local_metric" != "balance" ]] && [[ "$local_metric" != "pnl" ]] && [[ "$local_metric" != "hyperliquid_whales" ]]; then
      echo '{"error": "--metric invalid. Valid: balance, pnl, hyperliquid_whales"}' >&2; exit 1
    fi
    local_qs="metric=$(surf_urlencode "$local_metric")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/top" "$local_qs"
    ;;

  transfers)
    shift
    local_address="" local_chain="eth" local_limit="20" local_offset="0"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --address) local_address="$2"; shift 2 ;;
        --chain) local_chain="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --offset) local_offset="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --address, --chain, --limit, --offset\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_address" ]]; then
      echo '{"error": "--address is required (hex format for EVM, base58 for Solana)"}' >&2; exit 1
    fi
    if [[ -n "$local_chain" ]] && [[ "$local_chain" != "eth" ]] && [[ "$local_chain" != "solana" ]]; then
      echo '{"error": "--chain invalid. Valid: eth, solana"}' >&2; exit 1
    fi
    local_qs="address=$(surf_urlencode "$local_address")"
    [[ -n "$local_chain" ]] && local_qs="${local_qs:+${local_qs}&}chain=$local_chain"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_offset" ]] && local_qs="${local_qs:+${local_qs}&}offset=$local_offset"
    surf_get "${API_PREFIX}/transfers" "$local_qs"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
