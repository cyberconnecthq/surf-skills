#!/usr/bin/env bash
# surf-web — CLI for web data via Hermod API
# Usage: surf-web <subcommand> [flags]

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

API_PREFIX="/v1/web"

ALL_COMMANDS="fetch, search"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-web",
  "subcommands": {
    "fetch": {"args": "", "description": "Fetch and parse a URL (1 credit)"},
    "search": {"args": "--query bitcoin [--limit 20] [--site coindesk.com]", "description": "Search the web (1 credit)"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  fetch)
    shift
    local_url="" local_target="" local_remove=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url) local_url="$2"; shift 2 ;;
        --target-selector) local_target="$2"; shift 2 ;;
        --remove-selector) local_remove="$2"; shift 2 ;;
        *) echo '{"error": "Unknown flag: $1. Valid: --url, --target-selector, --remove-selector"}' >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_url" ]]; then
      echo '{"error": "--url is required (e.g. https://ethereum.org)"}' >&2; exit 1
    fi
    local_json="{\"url\": \"$local_url\""
    [[ -n "$local_target" ]] && local_json="$local_json, \"target_selector\": \"$local_target\""
    [[ -n "$local_remove" ]] && local_json="$local_json, \"remove_selector\": \"$local_remove\""
    local_json="$local_json}"
    surf_post "${API_PREFIX}/fetch" "$local_json"
    ;;

  search)
    shift
    local_query="" local_limit="20" local_site=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query) local_query="$2"; shift 2 ;;
        --limit) local_limit="$2"; shift 2 ;;
        --site) local_site="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit, --site\"}" >&2; exit 1 ;;
      esac
    done
    if [[ -z "$local_query" ]]; then
      echo '{"error": "--query is required (e.g. bitcoin price prediction 2026)"}' >&2; exit 1
    fi
    local_qs="q=$(surf_urlencode "$local_query")"
    [[ -n "$local_limit" ]] && local_qs="${local_qs:+${local_qs}&}limit=$local_limit"
    [[ -n "$local_site" ]] && local_qs="${local_qs:+${local_qs}&}site=$local_site"
    surf_get "${API_PREFIX}/search" "$local_qs"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
