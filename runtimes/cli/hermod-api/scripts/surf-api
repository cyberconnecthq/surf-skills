#!/usr/bin/env bash
# surf-api — Fetch, cache, and query Hermod OpenAPI specs
# Specs are saved to ~/.surf-core/api-docs/ for offline use by agents.

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
# Source config (loads HERMOD_URL + HERMOD_TOKEN from session)
source "$SCRIPT_DIR/../../lib/config.sh"

# Detect monorepo root (surf-core lives inside surf-v2-mono)
# SURF_CORE_ROOT is set by config.sh (points to runtimes/cli/), go up 2 more levels
SURF_CORE_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
MONOREPO_ROOT=""
if [[ -d "$SURF_CORE_ROOT/../hermod" ]]; then
  MONOREPO_ROOT="$(cd "$SURF_CORE_ROOT/.." && pwd)"
fi

QUERY_PY="$SCRIPT_DIR/_api_query.py"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-api",
  "subcommands": {
    "sync":      {"args": "", "description": "Fetch Swagger spec from Hermod live API (or monorepo fallback), save to ~/.surf-core/api-docs/"},
    "endpoints": {"args": "[CATEGORY]", "description": "List endpoints. Category: market, wallet, token, project, social, news, web, onchain, ..."},
    "show":      {"args": "<path>", "description": "Show endpoint details + curl example. e.g. show /market/price"},
    "search":    {"args": "<query>", "description": "Search endpoints by keyword. e.g. search bitcoin, search holders"},
    "status":    {"args": "", "description": "Show sync status, file locations, last sync time"},
    "--check-setup": {"args": "", "description": "Verify configuration"}
  },
  "examples": [
    "surf-api sync",
    "surf-api endpoints market",
    "surf-api show /market/price",
    "surf-api search holders",
    "surf-api endpoints | python3 -c \"import json,sys; [print(e['method'], e['path']) for e in json.load(sys.stdin)['endpoints']]\""
  ],
  "storage": "~/.surf-core/api-docs/"
}}
EOF
}

case "${1:---help}" in
  --help|-h)
    usage ;;
  --check-setup)
    surf_check_setup ;;
  sync)
    python3 "$QUERY_PY" sync "${HERMOD_URL:-}" "${HERMOD_TOKEN:-}" "${MONOREPO_ROOT:-}" ;;
  endpoints)
    shift
    python3 "$QUERY_PY" endpoints "${1:-}" ;;
  show)
    shift
    if [[ -z "${1:-}" ]]; then
      echo '{"error": "Usage: surf-api show <path>. Example: surf-api show /market/price"}' >&2
      exit 1
    fi
    python3 "$QUERY_PY" show "$1" ;;
  search)
    shift
    if [[ -z "${1:-}" ]]; then
      echo '{"error": "Usage: surf-api search <query>. Example: surf-api search bitcoin"}' >&2
      exit 1
    fi
    python3 "$QUERY_PY" search "$1" ;;
  status)
    python3 "$QUERY_PY" status ;;
  *)
    echo "{\"error\": \"Unknown command: $1. Available: sync, endpoints, show, search, status\"}" >&2
    exit 1 ;;
esac
