#!/usr/bin/env bash
# surf-project — CLI for crypto project data via Hermod API
# Usage: surf-project <subcommand> [flags]
#
# Hermod routes project endpoints to two upstreams:
#   - overview/token-info/funding/team/social/contract-address → Muninn (query param)
#   - volume/fee/revenue/tvl/users → Token Terminal (project_id param)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../../../lib/config.sh"
source "$SCRIPT_DIR/../../../lib/http.sh"

API_PREFIX="/v1/project"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-project",
  "subcommands": {
    "overview":         {"args": "--query aave", "description": "Project overview via Muninn (1 credit)"},
    "token-info":       {"args": "--query uniswap", "description": "Token info via Muninn (1 credit)"},
    "funding":          {"args": "--query aave", "description": "Funding rounds via Muninn (1 credit)"},
    "team":             {"args": "--query aave", "description": "Team members via Muninn (1 credit)"},
    "contract-address": {"args": "--query aave", "description": "Contract addresses via Muninn (1 credit)"},
    "social":           {"args": "--query aave", "description": "Social links via Muninn (1 credit)"},
    "volume":           {"args": "--project-id uniswap", "description": "Volume via Token Terminal (1 credit)"},
    "fee":              {"args": "--project-id uniswap", "description": "Fees via Token Terminal (1 credit)"},
    "revenue":          {"args": "--project-id lido", "description": "Revenue via Token Terminal (1 credit)"},
    "tvl":              {"args": "--project-id aave", "description": "TVL via Token Terminal (1 credit)"},
    "users":            {"args": "--project-id opensea", "description": "Users via Token Terminal (1 credit)"},
    "search":           {"args": "--query NAME [--limit 5]", "description": "Muninn project search (1 credit, proxy)"},
    "tt-metrics":       {"args": "--project-id aave --metrics revenue,tvl [--start DATE] [--end DATE]", "description": "Token Terminal metrics (2 credits, proxy)"},
    "tt-ranking":       {"args": "--metric tvl [--project-ids aave,uniswap]", "description": "Token Terminal ranking (2 credits, proxy)"},
    "--check-setup":    {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --query)      query="${query:+$query&}query=$2"; shift 2 ;;
      --project-id) query="${query:+$query&}project_id=$2"; shift 2 ;;
      --interval)   query="${query:+$query&}interval=$2"; shift 2 ;;
      --limit)      query="${query:+$query&}limit=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Muninn-backed endpoints (use --query)
  overview|token-info|funding|team|contract-address|social)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  # Token Terminal-backed endpoints (use --project-id)
  volume|fee|revenue|tvl|users)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  # Muninn proxy — project search
  search)
    shift
    query=$(build_query "$@")
    surf_proxy_get "muninn" "/v1/agents/search" "$query"
    ;;

  # Token Terminal proxy — metrics
  tt-metrics)
    shift; pid=""; metrics=""; start_date=""; end_date=""; chains=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --project-id) pid="$2"; shift 2 ;; --metrics) metrics="$2"; shift 2 ;;
        --start) start_date="$2"; shift 2 ;; --end) end_date="$2"; shift 2 ;;
        --chains) chains="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;;
      esac
    done
    [[ -z "$pid" ]] && { echo '{"error": "--project-id is required (e.g. aave, uniswap)"}' >&2; exit 1; }
    [[ -z "$metrics" ]] && { echo '{"error": "--metrics is required (e.g. revenue,tvl,fees)"}' >&2; exit 1; }
    q="metric_ids=${metrics}"
    [[ -n "$start_date" ]] && q="${q}&start=${start_date}"
    [[ -n "$end_date" ]] && q="${q}&end=${end_date}"
    [[ -n "$chains" ]] && q="${q}&chain_ids=${chains}"
    surf_proxy_get "tt" "/v2/projects/${pid}/metrics" "$q"
    ;;

  # Token Terminal proxy — rankings
  tt-ranking)
    shift; metric=""; pids=""
    while [[ $# -gt 0 ]]; do case "$1" in --metric) metric="$2"; shift 2 ;; --project-ids) pids="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$metric" ]] && { echo '{"error": "--metric is required (e.g. tvl, revenue, fees)"}' >&2; exit 1; }
    q=""; [[ -n "$pids" ]] && q="project_ids=${pids}"
    surf_proxy_get "tt" "/v2/metrics/${metric}" "$q"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Use --help for usage.\"}" >&2; exit 1 ;;
esac
