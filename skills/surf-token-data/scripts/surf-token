#!/usr/bin/env bash
# surf-token — CLI for token data via Hermod API
# Usage: surf-token <subcommand> [flags]
#
# Hermod routes token endpoints to different upstreams:
#   - holder/transfer → Moralis/Etherscan (token address + chain)
#   - exchange-flow/exchange-reserve → CryptoQuant (asset symbol)
#   - etf-flow → SoSoValue (type)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../../../lib/config.sh"
source "$SCRIPT_DIR/../../../lib/http.sh"

API_PREFIX="/v1/token-data"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-token",
  "subcommands": {
    "holder":           {"args": "--token 0x... --chain eth [--limit 5]", "description": "Moralis token holders (1 credit)"},
    "transfer":         {"args": "--token 0x... --chain eth [--page 1] [--offset 5]", "description": "Etherscan token transfers (1 credit)"},
    "exchange-flow":    {"args": "--asset btc --flow-type netflow [--exchange all_exchange] [--window day] [--limit 3]", "description": "CryptoQuant exchange flow (1 credit)"},
    "etf-flow":         {"args": "--type us-btc-spot", "description": "SoSoValue ETF flow (1 credit)"},
    "exchange-reserve": {"args": "--asset btc [--exchange all_exchange] [--window day] [--limit 3]", "description": "CryptoQuant exchange reserve (1 credit)"},
    "moralis-holders":  {"args": "--token ADDR [--chain eth]", "description": "Moralis top holders (2 credits, proxy)"},
    "moralis-meta":     {"args": "--token ADDR [--chain eth]", "description": "Moralis token metadata (2 credits, proxy)"},
    "moralis-transfers":{"args": "--token ADDR [--chain eth] [--limit 100]", "description": "Moralis token transfers (2 credits, proxy)"},
    "sol-holders":      {"args": "--token MINT [--page 1]", "description": "Solscan token holders (4 credits, proxy)"},
    "sol-transfers":    {"args": "--token MINT [--page 1]", "description": "Solscan token transfers (4 credits, proxy)"},
    "sol-price":        {"args": "--token MINT", "description": "Solscan token price (4 credits, proxy)"},
    "--check-setup":    {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

build_query() {
  local query=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --token)     query="${query:+$query&}token=$2"; shift 2 ;;
      --chain)     query="${query:+$query&}chain=$2"; shift 2 ;;
      --asset)     query="${query:+$query&}asset=$2"; shift 2 ;;
      --flow-type) query="${query:+$query&}flow_type=$2"; shift 2 ;;
      --exchange)  query="${query:+$query&}exchange=$2"; shift 2 ;;
      --window)    query="${query:+$query&}window=$2"; shift 2 ;;
      --type)      query="${query:+$query&}type=$2"; shift 2 ;;
      --limit)     query="${query:+$query&}limit=$2"; shift 2 ;;
      --page)      query="${query:+$query&}page=$2"; shift 2 ;;
      --offset)    query="${query:+$query&}offset=$2"; shift 2 ;;
      *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; return 1 ;;
    esac
  done
  echo "$query"
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  # Semantic endpoints
  holder|transfer|exchange-flow|etf-flow|exchange-reserve)
    subcmd="$1"; shift
    query=$(build_query "$@")
    surf_get "${API_PREFIX}/${subcmd}" "$query"
    ;;

  # Moralis proxy
  moralis-holders)
    shift; token=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/${token}/owners" "chain=${chain}&order=DESC&limit=100"
    ;;
  moralis-meta)
    shift; token=""; chain="eth"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/metadata" "chain=${chain}&addresses[]=${token}"
    ;;
  moralis-transfers)
    shift; token=""; chain="eth"; limit="100"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --chain) chain="$2"; shift 2 ;; --limit) limit="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (contract address)"}' >&2; exit 1; }
    surf_proxy_get "moralis" "/api/v2.2/erc20/${token}/transfers" "chain=${chain}&limit=${limit}"
    ;;

  # Solscan proxy
  sol-holders)
    shift; token=""; page="1"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/holders" "token=${token}&page=${page}&page_size=100"
    ;;
  sol-transfers)
    shift; token=""; page="1"
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; --page) page="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/transfer" "token=${token}&page=${page}&page_size=100"
    ;;
  sol-price)
    shift; token=""
    while [[ $# -gt 0 ]]; do case "$1" in --token) token="$2"; shift 2 ;; *) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;; esac; done
    [[ -z "$token" ]] && { echo '{"error": "--token is required (SPL mint address)"}' >&2; exit 1; }
    surf_proxy_get "solscan" "/v2.0/token/price" "token=${token}"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Use --help for usage.\"}" >&2; exit 1 ;;
esac
