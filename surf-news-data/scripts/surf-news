#!/usr/bin/env bash
# surf-news — CLI for crypto news search via Hermod API
# Usage: surf-news <subcommand> [flags]
#
# Hermod news search uses OpenSearch with semantic ranking + time-decay boosting.

set -euo pipefail

# Resolve symlinks so ../../lib/ works even when installed via `npx skills add`
_resolve_path() { python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"; }
SCRIPT_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../lib/config.sh"
source "$SCRIPT_DIR/../../lib/http.sh"

ALL_COMMANDS="search"

usage() {
  cat <<'EOF'
{"usage": {
  "command": "surf-news",
  "subcommands": {
    "search":       {"args": "--query TEXT [--limit 5] [--offset 0] [--project PROJECT] [--source SOURCE] [--from TIMESTAMP] [--to TIMESTAMP]", "description": "Search crypto news articles with semantic ranking and recency boost (1 credit). WARNING: large limit returns big JSON, use --limit"},
    "--check-setup": {"args": "", "description": "Verify environment configuration"}
  }
}}
EOF
}

# Main dispatch
case "${1:---help}" in
  --check-setup) surf_check_setup ;;
  --help|-h) usage ;;

  search)
    shift
    query=""; limit="5"; offset=""; project=""; source_filter=""; from_time=""; to_time=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --query)   query="$2"; shift 2 ;;
        --limit)   limit="$2"; shift 2 ;;
        --offset)  offset="$2"; shift 2 ;;
        --project) project="$2"; shift 2 ;;
        --source)  source_filter="$2"; shift 2 ;;
        --from)    from_time="$2"; shift 2 ;;
        --to)      to_time="$2"; shift 2 ;;
        *) echo "{\"error\": \"Unknown flag: $1. Valid: --query, --limit, --offset, --project, --source, --from, --to\"}" >&2; exit 1 ;;
      esac
    done
    [[ -z "$query" ]] && { echo '{"error": "--query is required (search text, e.g. bitcoin ETF)"}' >&2; exit 1; }

    # Build JSON body
    body="{\"query\":\"${query}\",\"limit\":${limit}"
    [[ -n "$offset" ]] && body="${body},\"offset\":${offset}"
    [[ -n "$project" ]] && body="${body},\"project_name\":\"${project}\""
    [[ -n "$source_filter" ]] && body="${body},\"source\":\"${source_filter}\""
    [[ -n "$from_time" ]] && body="${body},\"from_time\":${from_time}"
    [[ -n "$to_time" ]] && body="${body},\"to_time\":${to_time}"
    body="${body}}"

    surf_post "/v1/news/search" "$body"
    ;;

  *) echo "{\"error\": \"Unknown command: $1. Available: ${ALL_COMMANDS}\"}" >&2; exit 1 ;;
esac
